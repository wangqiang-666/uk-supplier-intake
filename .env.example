# Copy to .env (do not commit .env)
SRA_API_KEY=YOUR_SRA_SUBSCRIPTION_KEY
SRA_API_URL=https://sra-prod-apim.azure-api.net/datashare/api/V1/organisation/GetAll
PORT=3000
WORK_AREAS=Immigration,Private client
MAX_ORGS=0

# Faculty Office / NotaryPRO scraper
# (no API key needed - public Drupal views)
FACULTYOFFICE_MAX_PAGES=0        # 0 = scrape all pages (84 pages, ~756 notaries)
FACULTYOFFICE_DELAY_MS=1500       # delay between requests (ms)